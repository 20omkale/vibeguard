# VibeGuard Configuration
# ─────────────────────────────────────────────────────────────
# Run `python vibeguard.py config` for guided setup (recommended).
# Or manually set ONE of the keys below and VibeGuard will auto-detect it.
# ─────────────────────────────────────────────────────────────

# ── FREE TIER PROVIDERS (No credit card needed!) ──────────────

# Groq FREE — llama3-70b, 14,400 requests/day
# Get key at: https://console.groq.com (30 seconds, no credit card)
GROQ_API_KEY=your_key_here

# Google Gemini FREE — gemini-1.5-flash, generous free quota
# Get key at: https://aistudio.google.com
GEMINI_API_KEY=your_key_here

# ── PAID PROVIDERS (Best quality) ────────────────────────────

# OpenAI GPT-4o
OPENAI_API_KEY=your_key_here

# Anthropic Claude 3.5 Sonnet
ANTHROPIC_API_KEY=your_key_here

# ── OFFLINE MODE ──────────────────────────────────────────────
# No key needed. Requires Ollama installed: https://ollama.com
# Then run: ollama pull llama3
# (Uses llama3 by default, ~4GB download)

# ── PROJECT SETTINGS ─────────────────────────────────────────
VIBEGUARD_SCAN_DEPTH=5
VIBEGUARD_IGNORE_DIRS=node_modules,__pycache__,.git,dist,build,.next,venv
VIBEGUARD_SCORE_BASELINE=5000
