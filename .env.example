# VibeGuard Configuration
# Copy this file to .env and fill in your values

# Optional: OpenAI key for enhanced AI diagnosis
OPENAI_API_KEY=your_key_here

# Optional: Anthropic key for Claude-powered analysis
ANTHROPIC_API_KEY=your_key_here

# VibeGuard settings
VIBEGUARD_SCAN_DEPTH=5          # Max directory depth to scan
VIBEGUARD_IGNORE_DIRS=node_modules,__pycache__,.git,dist,build,.next,venv
VIBEGUARD_SCORE_BASELINE=5000   # Baseline score to compare against
